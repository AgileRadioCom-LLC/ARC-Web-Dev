---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="News &amp; Updates | AgileRadioCom"
  description="AgileRadioCom news and updates — latest announcements, research milestones, and product launches."
  bodyClass="bg-arc-dark text-white font-sans antialiased"
>

<!-- ════════════════════════════════════════════════════════════════════════
     PAGE HERO BANNER
════════════════════════════════════════════════════════════════════════════ -->
<section class="relative pt-16 pb-16 bg-arc-dark overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[300px] rounded-full bg-arc-accent/5 blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-arc-accent/30 to-transparent"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-arc-accent text-sm font-semibold tracking-widest uppercase mb-3" data-aos="fade-down">Latest</p>
    <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-black text-white mb-5" data-aos="fade-up" data-aos-delay="80">
      News &amp; <span class="text-arc-accent">Updates</span>
    </h1>
    <p class="text-arc-muted text-lg max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="160">
      Announcements, research milestones, and product launches from the AgileRadioCom team.
    </p>
  </div>
</section>


<!-- ════════════════════════════════════════════════════════════════════════
     FEATURED ARTICLE — top story in a wide two-column card
════════════════════════════════════════════════════════════════════════════ -->
<section class="py-16 bg-arc-navy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="flex items-center gap-3 mb-8" data-aos="fade-right">
      <span class="tag tag-accent">Featured</span>
      <div class="flex-1 h-px bg-arc-blue/30"></div>
    </div>

    <!-- Wide featured card: image left, text right on desktop -->
    <article class="news-card group grid grid-cols-1 lg:grid-cols-2 rounded-2xl border border-arc-accent/30 overflow-hidden hover:border-arc-accent/60 transition-all duration-300"
             data-aos="fade-up">
      <div class="h-64 lg:h-auto overflow-hidden bg-arc-dark">
        <img src="images/news-featured.jpg" alt="ArcSynerCom platform achieves sub-microsecond timing in field tests"
             class="w-full h-full object-cover opacity-75 group-hover:scale-105 group-hover:opacity-90 transition-all duration-500" loading="lazy"
             onerror="this.parentElement.classList.add('news-img-placeholder')" />
      </div>
      <div class="p-8 lg:p-10 flex flex-col justify-center">
        <div class="flex items-center gap-3 mb-4">
          <span class="tag tag-accent">Product Launch</span>
          <time class="text-arc-muted/60 text-xs" datetime="2026-05-15">May 2026</time>
        </div>
        <h2 class="font-display text-2xl font-bold text-white mb-3 group-hover:text-arc-accent transition-colors leading-snug">
          ArcSynerCom™ Platform Achieves Sub-Microsecond Timing in Field Tests
        </h2>
        <p class="text-arc-muted leading-relaxed mb-6">
          Our deterministic edge node demonstrates breakthrough precision timing synchronization
          for UAV swarm coordination in challenging RF environments. The milestone paves the way for
          large-scale autonomous drone deployments across defense and industrial sectors.
        </p>
        <a href="#" class="inline-flex items-center gap-2 text-arc-accent font-semibold text-sm hover:text-white transition-colors">
          Read full article
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </article>
  </div>
</section>


<!-- ════════════════════════════════════════════════════════════════════════
     ALL ARTICLES GRID — 3-column responsive grid
════════════════════════════════════════════════════════════════════════════ -->
<section class="py-16 bg-arc-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="flex items-center gap-3 mb-10" data-aos="fade-right">
      <p class="text-arc-muted text-sm font-semibold tracking-widest uppercase">All Articles</p>
      <div class="flex-1 h-px bg-arc-blue/30"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">

      <!-- Article 1 -->
      <article class="news-card group" data-aos="fade-up" data-aos-delay="0">
        <div class="h-48 overflow-hidden rounded-t-2xl bg-arc-navy">
          <img src="images/news-1.jpg" alt="AgileRadioCom joins O-RAN Alliance"
               class="w-full h-full object-cover opacity-70 group-hover:scale-105 group-hover:opacity-90 transition-all duration-500" loading="lazy"
               onerror="this.parentElement.classList.add('news-img-placeholder')" />
        </div>
        <div class="p-6">
          <div class="flex items-center gap-3 mb-3">
            <span class="tag tag-blue">Partnership</span>
            <time class="text-arc-muted/60 text-xs" datetime="2026-04-10">April 2026</time>
          </div>
          <h3 class="font-display font-bold text-white text-base mb-2 group-hover:text-arc-accent transition-colors leading-snug">
            AgileRadioCom Joins O-RAN Alliance to Advance Open RAN Innovation
          </h3>
          <p class="text-arc-muted text-sm leading-relaxed line-clamp-3">
            Joining the O-RAN Alliance underscores our commitment to open, standards-based wireless
            architectures that enable true multi-vendor interoperability across 5G/6G networks.
          </p>
          <a href="#" class="inline-flex items-center gap-1.5 mt-4 text-arc-accent text-xs font-semibold hover:text-white transition-colors">Read more →</a>
        </div>
      </article>

      <!-- Article 2 -->
      <article class="news-card group" data-aos="fade-up" data-aos-delay="80">
        <div class="h-48 overflow-hidden rounded-t-2xl bg-arc-navy">
          <img src="images/news-2.jpg" alt="ArcSecureCom jam-resistant field test"
               class="w-full h-full object-cover opacity-70 group-hover:scale-105 group-hover:opacity-90 transition-all duration-500" loading="lazy"
               onerror="this.parentElement.classList.add('news-img-placeholder')" />
        </div>
        <div class="p-6">
          <div class="flex items-center gap-3 mb-3">
            <span class="tag tag-gold">Research</span>
            <time class="text-arc-muted/60 text-xs" datetime="2026-03-22">March 2026</time>
          </div>
          <h3 class="font-display font-bold text-white text-base mb-2 group-hover:text-arc-accent transition-colors leading-snug">
            ArcSecureCom™ Demonstrates Jam-Resistant Comms in Multi-Domain Test
          </h3>
          <p class="text-arc-muted text-sm leading-relaxed line-clamp-3">
            Our military-grade SDR platform successfully maintained secure communications under
            aggressive electronic warfare jamming scenarios across contested spectrum.
          </p>
          <a href="#" class="inline-flex items-center gap-1.5 mt-4 text-arc-accent text-xs font-semibold hover:text-white transition-colors">Read more →</a>
        </div>
      </article>

      <!-- Article 3 -->
      <article class="news-card group" data-aos="fade-up" data-aos-delay="160">
        <div class="h-48 overflow-hidden rounded-t-2xl bg-arc-navy">
          <img src="images/news-3.jpg" alt="ArcSafeLink IoT safety validation"
               class="w-full h-full object-cover opacity-70 group-hover:scale-105 group-hover:opacity-90 transition-all duration-500" loading="lazy"
               onerror="this.parentElement.classList.add('news-img-placeholder')" />
        </div>
        <div class="p-6">
          <div class="flex items-center gap-3 mb-3">
            <span class="tag tag-blue">Product</span>
            <time class="text-arc-muted/60 text-xs" datetime="2026-02-14">February 2026</time>
          </div>
          <h3 class="font-display font-bold text-white text-base mb-2 group-hover:text-arc-accent transition-colors leading-snug">
            ArcSafeLink™ Certified for IEC 62280 Railway Safety Applications
          </h3>
          <p class="text-arc-muted text-sm leading-relaxed line-clamp-3">
            ArcSafeLink's bounded latency and wire-like wireless reliability now meet stringent IEC 62280
            requirements for safety-critical railway signalling communications.
          </p>
          <a href="#" class="inline-flex items-center gap-1.5 mt-4 text-arc-accent text-xs font-semibold hover:text-white transition-colors">Read more →</a>
        </div>
      </article>

      <!-- Article 4 -->
      <article class="news-card group" data-aos="fade-up" data-aos-delay="0">
        <div class="h-48 overflow-hidden rounded-t-2xl bg-arc-navy">
          <img src="images/news-4.jpg" alt="ArcAeroConnect NTN satellite integration"
               class="w-full h-full object-cover opacity-70 group-hover:scale-105 group-hover:opacity-90 transition-all duration-500" loading="lazy"
               onerror="this.parentElement.classList.add('news-img-placeholder')" />
        </div>
        <div class="p-6">
          <div class="flex items-center gap-3 mb-3">
            <span class="tag tag-accent">Milestone</span>
            <time class="text-arc-muted/60 text-xs" datetime="2026-01-30">January 2026</time>
          </div>
          <h3 class="font-display font-bold text-white text-base mb-2 group-hover:text-arc-accent transition-colors leading-snug">
            ArcAeroConnect™ Successfully Integrates NTN Satellite Link for Drone Swarms
          </h3>
          <p class="text-arc-muted text-sm leading-relaxed line-clamp-3">
            Our aerospace platform achieves seamless Non-Terrestrial Network integration, enabling
            coordinated drone swarm operations beyond line-of-sight via satellite relay.
          </p>
          <a href="#" class="inline-flex items-center gap-1.5 mt-4 text-arc-accent text-xs font-semibold hover:text-white transition-colors">Read more →</a>
        </div>
      </article>

      <!-- Article 5 -->
      <article class="news-card group" data-aos="fade-up" data-aos-delay="80">
        <div class="h-48 overflow-hidden rounded-t-2xl bg-arc-navy">
          <img src="images/news-5.jpg" alt="Digital twin REST API integration"
               class="w-full h-full object-cover opacity-70 group-hover:scale-105 group-hover:opacity-90 transition-all duration-500" loading="lazy"
               onerror="this.parentElement.classList.add('news-img-placeholder')" />
        </div>
        <div class="p-6">
          <div class="flex items-center gap-3 mb-3">
            <span class="tag tag-blue">Integration</span>
            <time class="text-arc-muted/60 text-xs" datetime="2025-12-10">December 2025</time>
          </div>
          <h3 class="font-display font-bold text-white text-base mb-2 group-hover:text-arc-accent transition-colors leading-snug">
            ArcSynerCom™ REST API Enables Real-Time Digital Twin Synchronization
          </h3>
          <p class="text-arc-muted text-sm leading-relaxed line-clamp-3">
            New REST API endpoints allow industrial operators to sync physical network state with
            digital twin environments for predictive maintenance and simulation-driven optimization.
          </p>
          <a href="#" class="inline-flex items-center gap-1.5 mt-4 text-arc-accent text-xs font-semibold hover:text-white transition-colors">Read more →</a>
        </div>
      </article>

      <!-- Article 6 -->
      <article class="news-card group" data-aos="fade-up" data-aos-delay="160">
        <div class="h-48 overflow-hidden rounded-t-2xl bg-arc-navy">
          <img src="images/news-6.jpg" alt="AgileRadioCom at IEEE GLOBECOM"
               class="w-full h-full object-cover opacity-70 group-hover:scale-105 group-hover:opacity-90 transition-all duration-500" loading="lazy"
               onerror="this.parentElement.classList.add('news-img-placeholder')" />
        </div>
        <div class="p-6">
          <div class="flex items-center gap-3 mb-3">
            <span class="tag tag-gold">Event</span>
            <time class="text-arc-muted/60 text-xs" datetime="2025-11-20">November 2025</time>
          </div>
          <h3 class="font-display font-bold text-white text-base mb-2 group-hover:text-arc-accent transition-colors leading-snug">
            AgileRadioCom Presents D-SDR™ Research at IEEE GLOBECOM 2025
          </h3>
          <p class="text-arc-muted text-sm leading-relaxed line-clamp-3">
            Dr. Sisay Tadesse Arzo and Dr. Petro Mushidi Tshakwanda presented groundbreaking
            deterministic SDR research at the IEEE Global Communications Conference in Cape Town.
          </p>
          <a href="#" class="inline-flex items-center gap-1.5 mt-4 text-arc-accent text-xs font-semibold hover:text-white transition-colors">Read more →</a>
        </div>
      </article>

    </div><!-- /articles grid -->

    <!-- Newsletter / stay-in-touch strip -->
    <div class="mt-16 rounded-2xl border border-arc-accent/20 bg-arc-navy p-8 md:p-10 text-center" data-aos="fade-up">
      <h3 class="font-display text-2xl font-bold text-white mb-3">Stay in the Loop</h3>
      <p class="text-arc-muted mb-6 max-w-md mx-auto">
        Get the latest AgileRadioCom news and product updates delivered straight to your inbox.
      </p>
      <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-full bg-arc-accent text-arc-dark font-bold hover:bg-white transition-colors">
        Contact Us to Subscribe
      </a>
    </div>
  </div>
</section>

</Layout>
