---
const { pathname } = Astro.url;
const isActive = (path: string) =>
  path === '/' ? pathname === '/' : pathname.startsWith(path);
---

<header id="navbar" class="relative bg-arc-dark border-b border-arc-blue/30">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20 md:h-28">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3" aria-label="AgileRadioCom Home">
        <img src="/images/arc-logo.png" alt="AgileRadioCom logo" class="h-14 md:h-20 w-auto object-contain"
             loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
        <span class="hidden items-center text-xl font-display font-black">
          <span class="text-arc-accent">ARC</span><span class="text-white">RadioCom</span>
        </span>
      </a>

      <!-- Desktop nav links -->
      <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-arc-muted">
        <li><a href="/"         class={`nav-link ${isActive('/') ? 'active' : ''} hover:text-arc-accent transition-colors`}>Home</a></li>
        <li><a href="/about"    class={`nav-link ${isActive('/about') ? 'active' : ''} hover:text-arc-accent transition-colors`}>About Us</a></li>
        <li><a href="/products" class={`nav-link ${isActive('/products') ? 'active' : ''} hover:text-arc-accent transition-colors`}>Our Products</a></li>
        <li><a href="/news"     class={`nav-link ${isActive('/news') ? 'active' : ''} hover:text-arc-accent transition-colors`}>News &amp; Updates</a></li>
        <li><a href="/contact"  class={`nav-link ${isActive('/contact') ? 'active' : ''} hover:text-arc-accent transition-colors`}>Contact Us</a></li>
      </ul>

      <!-- Desktop CTA (hidden on contact page) -->
      {!isActive('/contact') && (
        <a href="/contact" class="hidden md:inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-arc-accent text-arc-dark text-sm font-semibold hover:bg-white transition-colors duration-200">
          Schedule a Demo
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      )}
      {isActive('/contact') && <div class="hidden md:block w-36"></div>}

      <!-- Mobile hamburger -->
      <button id="hamburger" class="md:hidden w-10 h-10 flex flex-col justify-center items-center gap-1.5 rounded-lg border border-arc-blue/50 text-arc-muted hover:text-arc-accent hover:border-arc-accent transition-colors"
              aria-label="Toggle mobile menu" aria-expanded="false" aria-controls="mobile-menu">
        <span class="hamburger-bar block w-5 h-0.5 bg-current transition-all duration-300"></span>
        <span class="hamburger-bar block w-5 h-0.5 bg-current transition-all duration-300"></span>
        <span class="hamburger-bar block w-5 h-0.5 bg-current transition-all duration-300"></span>
      </button>
    </div>

    <!-- Mobile dropdown -->
    <div id="mobile-menu" class="md:hidden overflow-hidden max-h-0 transition-all duration-300 ease-in-out" aria-hidden="true">
      <ul class="flex flex-col gap-1 pb-4 text-sm font-medium text-arc-muted border-t border-arc-blue/30 mt-2 pt-4">
        <li><a href="/"         class={`mobile-nav-link block px-3 py-2.5 rounded-lg hover:bg-arc-navy hover:text-arc-accent transition-colors ${isActive('/') ? 'text-arc-accent bg-arc-navy' : ''}`}>Home</a></li>
        <li><a href="/about"    class={`mobile-nav-link block px-3 py-2.5 rounded-lg hover:bg-arc-navy hover:text-arc-accent transition-colors ${isActive('/about') ? 'text-arc-accent bg-arc-navy' : ''}`}>About Us</a></li>
        <li><a href="/products" class={`mobile-nav-link block px-3 py-2.5 rounded-lg hover:bg-arc-navy hover:text-arc-accent transition-colors ${isActive('/products') ? 'text-arc-accent bg-arc-navy' : ''}`}>Our Products</a></li>
        <li><a href="/news"     class={`mobile-nav-link block px-3 py-2.5 rounded-lg hover:bg-arc-navy hover:text-arc-accent transition-colors ${isActive('/news') ? 'text-arc-accent bg-arc-navy' : ''}`}>News &amp; Updates</a></li>
        <li><a href="/contact"  class={`mobile-nav-link block px-3 py-2.5 rounded-lg hover:bg-arc-navy hover:text-arc-accent transition-colors ${isActive('/contact') ? 'text-arc-accent bg-arc-navy' : ''}`}>Contact Us</a></li>
        <li class="pt-2">
          <a href="/contact" class="block text-center px-5 py-2.5 rounded-full bg-arc-accent text-arc-dark font-semibold hover:bg-white transition-colors">Schedule a Demo</a>
        </li>
      </ul>
    </div>
  </nav>
</header>
